#!/usr/bin/env bash
# config — open tdub's config.json in $EDITOR. config.json holds your
# personal overrides; defaults.json (same dir, regenerated every launch)
# is the read-only reference with every setting and its default value.
set -e
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tdub"
CONFIG_FILE="$CONFIG_DIR/config.json"
mkdir -p "$CONFIG_DIR"
if [ ! -f "$CONFIG_FILE" ]; then
  cat > "$CONFIG_FILE" <<'JSON'
{
  "_comment": "Your overrides. Anything missing falls back to defaults.json (same dir). Reload on save.",
  "keybindings": {}
}
JSON
fi
exec "${EDITOR:-vi}" "$CONFIG_FILE"
