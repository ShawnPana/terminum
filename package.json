{
  "name": "ophanim",
  "version": "0.1.0",
  "description": "A terminal that can summon a browser.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0"
  },
  "build": {
    "appId": "com.shawnpana.ophanim",
    "productName": "Ophanim",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "renderer.js",
      "browser-preload.js",
      "browser-chrome.html",
      "config-ui.html",
      "index.html",
      "bin/**",
      "shell/**",
      "LICENSE",
      "!**/.DS_Store",
      "!**/*.{md,map}",
      "!shell/zsh/.zcompdump*",
      "!shell/zsh/.zsh_history",
      "!shell/zsh/.zsh_sessions"
    ],
    "asarUnpack": [
      "bin/**",
      "shell/**",
      "**/*.node"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "zip",
          "arch": "arm64"
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    }
  }
}
